{
  "name": "@wonderlandlabs-pixi-ux/monorepo",
  "version": "1.1.7",
  "description": "monorepo with grid, panel, drag packages, and other utilities for wonderlandlabs-pixi-ux",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:dev": "yarn workspace @wonderlandlabs-pixi-ux/docs dev",
    "docs:start": "yarn workspace @wonderlandlabs-pixi-ux/docs start",
    "docs:build": "yarn workspace @wonderlandlabs-pixi-ux/docs build",
    "package-validator:dev": "yarn workspace @wonderlandlabs-pixi-ux/package-validator dev",
    "package-validator:build": "yarn workspace @wonderlandlabs-pixi-ux/package-validator build",
    "package-validator:preview": "yarn workspace @wonderlandlabs-pixi-ux/package-validator preview",
    "build:validator-targets": "yarn workspace @wonderlandlabs-pixi-ux/root-container build && yarn workspace @wonderlandlabs-pixi-ux/grid build && yarn workspace @wonderlandlabs-pixi-ux/resizer build && yarn workspace @wonderlandlabs-pixi-ux/drag build",
    "validate:release": "yarn workspace @wonderlandlabs-pixi-ux/package-validator validate:release",
    "validate:release:built": "yarn build:validator-targets && yarn validate:release",
    "build": "yarn workspaces foreach -A run build",
    "clean": "yarn workspaces foreach -A run clean",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "publishAll": "yarn workspaces foreach -A --no-private -t npm publish --access public"
  },
  "devDependencies": {
    "@storybook/html-vite": "^10.1.12",
    "@types/node": "^25.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.3.10",
    "jsdom": "^27.4.0",
    "pixi.js": "8.16.0",
    "storybook": "^10.1.12",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  },
  "packageManager": "yarn@4.0.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
