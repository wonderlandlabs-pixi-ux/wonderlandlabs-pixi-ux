{
  "BASE": {
    "button": {
      "button": {
        "base": {
          "100": {
            "container": {
              "background": {
                "fill": {
                  "$*": "#183a37",
                  "$hover": "#1f3f6b"
                },
                "padding": {
                  "$*": [0, 40]
                }
              },
              "border": {
                "color": {
                  "$*": "#183a37",
                  "$hover": "#4f78ad"
                },
                "width": {
                  "$hover": 1
                },
                "radius": {
                  "$*": 24
                }
              }
            },
            "label": {
              "font": {
                "color": {
                  "$*": "#f7f4ea"
                }
              }
            },
            "icon": {
              "size": {
                "width": {
                  "$*": 24
                },
                "height": {
                  "$*": 24
                }
              }
            }
          }
        }
      }
    }
  }
}
