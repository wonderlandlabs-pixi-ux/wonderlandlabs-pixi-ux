{
  "container": {
    "background": {
      "base": {
        "$*": {
          "fill": "#183a37"
        },
        "$hover": {
          "fill": "#183a37"
        },
        "padding": {
          "$*": [0, 40]
        }
      }
    },
    "border": {
      "base": {
        "color": {
          "$*": "#183a37"
        },
        "radius": {
          "$*": 24
        }
      }
    }
  },
  "label": {
    "base": {
      "font": {
        "color": {
          "$*": "#f7f4ea"
        }
      }
    }
  },
  "icon": {
    "base": {
      "size": {
        "width": {
          "$*": 24
        },
        "height": {
          "$*": 24
        }
      }
    }
  }
}
