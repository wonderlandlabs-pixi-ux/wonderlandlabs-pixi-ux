{
  "container": {
    "background": {
      "padding": {
        "$*": [4, 17]
      },
      "width": {
        "$*": 200
      },
      "height": {
        "$*": 40
      },
      "$*": {
        "fill": "#FFFFFF"
      },
      "$dark": {
        "fill": "#000000"
      },
      "base": {
        "$start": {
          "fill": {
            "direction": "vertical",
            "colors": [
              "#E7E4DE",
              "#F4F2EE",
              "#FFFFFF",
              "#F2EFEB",
              "#D7D2CA"
            ]
          }
        }
      },
      "avatar": {
        "padding": {
          "$*": 15
        },
        "width": {
          "$*": 150
        },
        "height": {
          "$*": 150
        }
      },
      "vertical": {
        "padding": {
          "$*": 8
        },
        "width": {
          "$*": 60
        },
        "height": {
          "$*": 80
        }
      }
    },
    "content": {
      "gap": {
        "$*": 6
      },
      "vertical": {
        "gap": {
          "$*": 4
        }
      },
      "avatar": {
        "gap": {
          "$*": 8
        }
      }
    },
    "border": {
      "width": {
        "$*": 1
      },
      "color": {
        "$*": "#000000"
      },
      "radius": {
        "$*": 10
      },
      "$dark": {
        "color": "#FFFFFF"
      },
      "avatar": {
        "width": {
          "$*": 0
        },
        "radius": {
          "$*": 100
        }
      }
    }
  },
  "label": {
    "font": {
      "$*": [
        "Helvetica",
        "Arial",
        "sans-serif"
      ],
      "alpha": {
        "$*": 1,
        "$disabled": 0.45
      },
      "color": {
        "$*": "#000000",
        "$dark": "#FFFFFF"
      }
    },
    "size": {
      "$*": 17
    },
    "avatar": {
      "size": {
        "$*": 24
      }
    }
  },
  "icon": {
    "alpha": {
      "$*": 1,
      "$disabled": 0.45
    },
    "size": {
      "width": {
        "$*": 16
      },
      "height": {
        "$*": 16
      },
      "size": {
        "$*": 16
      }
    },
    "avatar": {
      "size": {
        "width": {
          "$*": 24
        },
        "height": {
          "$*": 24
        },
        "size": {
          "$*": 24
        }
      }
    }
  }
}
