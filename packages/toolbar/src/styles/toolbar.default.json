{
  "container": {
    "background": {
      "padding": {
        "$*": [4, 4]
      },
      "text": {
        "padding": {
          "$*": [6, 12]
        }
      },
      "vertical": {
        "padding": {
          "$*": [4, 4]
        }
      },
      "avatar": {
        "padding": {
          "$*": [6, 6]
        }
      }
    },
    "content": {
      "gap": {
        "$*": 6
      },
      "vertical": {
        "gap": {
          "$*": 4
        }
      }
    },
    "border": {
      "width": {
        "$*": 0,
        "$disabled": 1
      },
      "radius": {
        "$*": 4
      },
      "color": {
        "$disabled": "#b0b0b0"
      },
      "avatar": {
        "radius": {
          "$*": 999
        }
      }
    }
  },
  "label": {
    "size": {
      "$*": 12
    },
    "font": {
      "color": {
        "$*": "#111111",
        "$hover": "#000000",
        "$disabled": "#7a7a7a"
      },
      "alpha": {
        "$*": 0.7,
        "$hover": 1,
        "$disabled": 0.45
      }
    },
    "text": {
      "size": {
        "$*": 13
      }
    }
  },
  "icon": {
    "alpha": {
      "$*": 1,
      "$disabled": 0.45
    },
    "size": {
      "width": {
        "$*": 40
      },
      "height": {
        "$*": 40
      },
      "size": {
        "$*": 40
      }
    },
    "vertical": {
      "size": {
        "width": {
          "$*": 80
        },
        "height": {
          "$*": 80
        },
        "size": {
          "$*": 80
        }
      }
    },
    "avatar": {
      "size": {
        "width": {
          "$*": 48
        },
        "height": {
          "$*": 48
        },
        "size": {
          "$*": 48
        }
      }
    }
  }
}
